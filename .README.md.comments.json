      "blockType": "heading",
      "blockPreview": "# Markdown Review",
      "comment": "what is this extension about?",
      "role": "user",
      "timestamp": "2026-03-14T06:01:31.035Z",
      "resolved": false,
      "replies": [
        {
          "id": "r1773468114172",
          "role": "agent",
          "text": "Markdown Review is a VS Code extension that adds inline commenting and review capabilities to markdown files — similar to what you'd find in Google Docs or Quip. It lets you add comments on specific blocks of a markdown document, reply in threads, and resolve discussions, all without leaving VS Code. It also exposes 7 built-in Copilot tools so AI agents can participate in the review process — reading comments, replying, and resolving them. It's designed for document reviews, design proposals, and technical specs.",
          "timestamp": "2026-03-14T06:01:54.172Z"
        }
      ]
    }
  ]
